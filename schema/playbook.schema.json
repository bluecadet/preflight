{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://preflight.dev/schema/playbook.schema.json",
  "title": "Playbook",
  "description": "Schema for preflight playbook.yml files",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable playbook name"
    },
    "description": {
      "type": "string",
      "description": "Playbook description"
    },
    "defaults": {
      "$ref": "#/$defs/taskDefaults"
    },
    "vars": {
      "type": "object",
      "description": "Playbook-level variable overrides"
    },
    "import": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Other playbook files to merge before this one's tasks"
    },
    "tasks": {
      "type": "array",
      "description": "Ordered list of tasks",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable task ref used for dependency resolution"
        },
        "ref": {
          "type": "string",
          "description": "Alias for id when a shorter stable dependency key is preferred"
        },
        "name": {
          "type": "string",
          "description": "Human-readable label used in output and as a fallback dependency reference"
        },
        "uses": {
          "type": "string",
          "description": "Action reference, e.g. preflight/kiosk-mode, ./actions/local, github.com/org/name@v1"
        },
        "module": {
          "type": "string",
          "description": "Explicit module name, including plugin-backed modules"
        },
        "params": {
          "type": "object",
          "description": "Parameters passed to the explicit module"
        },
        "with": {
          "type": "object",
          "description": "Input values passed to the referenced action"
        },
        "become": {
          "$ref": "#/$defs/becomeConfig"
        },
        "when": {
          "type": "string",
          "description": "Template condition expression, e.g. {{ vars.enabled }}"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Task refs, or task names when no explicit ref is set"
        },
        "ignore_errors": {
          "type": "boolean",
          "description": "Continue execution even if this task fails"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags for filtering task execution"
        },
        "registry": { "$ref": "#/$defs/moduleRegistry" },
        "service": { "$ref": "#/$defs/moduleService" },
        "file": { "$ref": "#/$defs/moduleFile" },
        "directory": { "$ref": "#/$defs/moduleDirectory" },
        "package": { "$ref": "#/$defs/modulePackage" },
        "shortcut": { "$ref": "#/$defs/moduleShortcut" },
        "scheduled_task": { "$ref": "#/$defs/moduleScheduledTask" },
        "user": { "$ref": "#/$defs/moduleUser" },
        "winget_package": { "$ref": "#/$defs/moduleWingetPackage" },
        "remove_appx_packages": { "$ref": "#/$defs/moduleRemoveAppxPackages" },
        "power_plan": { "$ref": "#/$defs/modulePowerPlan" },
        "windows_feature": { "$ref": "#/$defs/moduleWindowsFeature" },
        "environment": { "$ref": "#/$defs/moduleEnvironment" },
        "firewall_rule": { "$ref": "#/$defs/moduleFirewallRule" },
        "powershell": { "$ref": "#/$defs/modulePowershell" },
        "shell": { "$ref": "#/$defs/moduleShell" },
        "reboot": { "$ref": "#/$defs/moduleReboot" },
        "wait": { "$ref": "#/$defs/moduleWait" }
      }
    },
    "taskDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "become": {
          "$ref": "#/$defs/becomeConfig"
        }
      }
    },
    "becomeConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "user": { "type": "string" },
        "password": { "type": "string" },
        "method": { "type": "string" },
        "load_profile": { "type": "boolean" }
      }
    },
    "moduleRegistry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "user": { "type": "string" },
        "values": {
          "oneOf": [
            { "type": "object" },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/registryValueSpec" }
            }
          ]
        },
        "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
      }
    },
    "registryValueSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["string", "expand_string", "dword", "qword", "binary", "multi_string"] },
        "data": {},
        "patch": {
          "type": "array",
          "items": { "$ref": "#/$defs/registryBinaryPatchSpec" }
        },
        "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
      }
    },
    "registryBinaryPatchSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["offset", "data"],
      "properties": {
        "offset": { "type": "integer", "minimum": 0 },
        "data": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 255 },
            { "type": "string" }
          ]
        }
      }
    },
    "moduleService": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "type": "string", "enum": ["running", "stopped", "disabled"] },
        "startup_type": { "type": "string", "enum": ["automatic", "manual", "disabled"] }
      }
    },
      "moduleFile": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "src": { "type": "string" },
          "dest": { "type": "string" },
          "content": { "type": "string" },
          "content_template": {
            "type": "string",
            "description": "Inline file content template to render before writing; supports secret(\"name\") placeholders"
          },
          "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
        }
      },
      "moduleDirectory": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
        }
      },
    "modulePackage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["product_id"],
            "properties": {
              "product_id": { "type": "string" },
              "source": { "type": "string" },
              "args": { "type": "array", "items": { "type": "string" } },
              "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
            }
          }
        },
        "source": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "product_id": { "type": "string" },
        "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
      }
    },
    "moduleShortcut": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": { "type": "string" },
        "destination": { "type": "string" },
        "args": { "type": "string" },
        "icon": { "type": "string" }
      }
    },
    "moduleScheduledTask": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "execute": { "type": "string" },
        "command": { "type": "string" },
        "arguments": { "type": "string" },
        "working_dir": { "type": "string" },
        "trigger": {
          "anyOf": [
            { "type": "string", "enum": ["startup", "onlogon", "daily", "once"] },
            { "type": "string" }
          ]
        },
        "start_at": { "type": "string" },
        "delay": { "type": "string" },
        "run_as": { "type": "string" },
        "user": { "type": "string" },
        "run_level": {
          "anyOf": [
            { "type": "string", "enum": ["least", "highest"] },
            { "type": "string" }
          ],
          "default": "least"
        },
        "enabled": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string" }
          ],
          "default": true
        },
        "ensure": {
          "anyOf": [
            { "type": "string", "enum": ["present", "absent"] },
            { "type": "string" }
          ],
          "default": "present"
        }
      }
    },
    "moduleUser": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "password": { "type": "string" },
        "groups": { "type": "array", "items": { "type": "string" } },
        "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
      }
    },
    "moduleWingetPackage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "description": "List of packages to manage",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "version": { "type": "string" },
              "source": { "type": "string" },
              "args": { "type": "array", "items": { "type": "string" } },
              "scope": { "type": "string", "enum": ["machine", "user"], "default": "machine" },
              "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
            }
          }
        },
        "id": { "type": "string", "description": "Legacy: single package identifier (use 'packages' instead)" },
        "version": { "type": "string" },
        "source": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "scope": { "type": "string", "enum": ["machine", "user"], "default": "machine" },
        "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
      }
    },
    "moduleRemoveAppxPackages": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "scope": { "type": "string", "enum": ["current_user", "all_users", "provisioned", "both"], "default": "both" },
              "ensure": { "type": "string", "enum": ["absent"], "default": "absent" }
            }
          }
        },
        "name": { "type": "string" },
        "scope": { "type": "string", "enum": ["current_user", "all_users", "provisioned", "both"], "default": "both" },
        "ensure": { "type": "string", "enum": ["absent"], "default": "absent" }
      }
    },
    "modulePowerPlan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "base": { "type": "string" },
        "activate": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string" }
          ],
          "default": true
        },
        "settings": { "type": "array", "items": { "$ref": "#/$defs/powerPlanSetting" } },
        "ensure": {
          "anyOf": [
            { "type": "string", "enum": ["present", "absent"] },
            { "type": "string" }
          ],
          "default": "present"
        }
      }
    },
    "powerPlanSetting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subgroup", "setting"],
      "properties": {
        "subgroup": { "type": "string" },
        "setting": { "type": "string" },
        "ac_value": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string" }
          ]
        },
        "dc_value": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string" }
          ]
        }
      }
    },
    "moduleWindowsFeature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
      }
    },
    "moduleEnvironment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "string" },
        "scope": { "type": "string", "enum": ["machine", "user"], "default": "machine" },
        "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
      }
    },
    "moduleFirewallRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "direction": { "type": "string", "enum": ["inbound", "outbound"] },
        "action": { "type": "string", "enum": ["allow", "block"] },
        "protocol": { "type": "string", "enum": ["tcp", "udp", "any"], "default": "tcp" },
        "ports": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string" },
            { "type": "array", "items": { "oneOf": [{ "type": "integer" }, { "type": "string" }] } }
          ]
        },
        "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
      }
    },
    "modulePowershell": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "script": { "type": "string" },
        "file": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "check_script": { "type": "string" },
        "creates": { "type": "string" },
        "env": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "moduleShell": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "creates": { "type": "string" },
        "working_dir": { "type": "string" },
        "env": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "moduleReboot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "condition": { "type": "string", "enum": ["always", "if_needed"], "default": "if_needed" },
        "timeout": { "type": "integer", "default": 300 }
      }
    },
    "moduleWait": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "target"],
      "properties": {
        "condition": { "type": "string", "enum": ["port_open", "file_exists", "service_running"] },
        "target": { "type": "string", "description": "The address:port, file path, or service name to check depending on condition" },
        "timeout": { "type": "string", "default": "5m" }
      }
    }
  }
}
