{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://preflight.dev/schema/action.schema.json",
  "title": "Action",
  "description": "Schema for preflight action.yml files",
  "type": "object",
  "required": ["name", "tasks"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Action name, optionally namespaced, e.g. org/action-name",
      "pattern": "^[a-zA-Z0-9._-]+(?:/[a-zA-Z0-9._/-]+)?$"
    },
    "version": {
      "type": "string",
      "description": "Semantic version, e.g. 1.2.0",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "defaults": {
      "$ref": "#/$defs/taskDefaults"
    },
    "inputs": {
      "type": "object",
      "description": "Map of named input definitions",
      "additionalProperties": {
        "$ref": "#/$defs/inputDef"
      }
    },
    "tasks": {
      "type": "array",
      "description": "Ordered list of tasks",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "inputDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "bool", "int", "path"]
        },
        "required": {
          "type": "boolean"
        },
        "default": {},
        "description": {
          "type": "string"
        }
      }
    },
    "task": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable task ref used for dependency resolution"
        },
        "name": {
          "type": "string",
          "description": "Human-readable label used in output and as a fallback dependency reference"
        },
        "uses": {
          "type": "string",
          "description": "Reference to another action, mutually exclusive with module fields"
        },
        "module": {
          "type": "string",
          "description": "Explicit module name, including plugin-backed modules"
        },
        "params": {
          "type": "object",
          "description": "Parameters passed to the explicit module"
        },
        "with": {
          "type": "object",
          "description": "Input values passed to the referenced action"
        },
        "become": {
          "$ref": "#/$defs/becomeConfig"
        },
        "when": {
          "type": "string",
          "description": "Template condition expression, e.g. {{ vars.enabled }}"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Task refs, or task names when no explicit ref is set"
        },
        "ignore_errors": {
          "type": "boolean",
          "description": "Continue execution even if this task fails"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags for filtering task execution"
        },
        "registry": { "$ref": "#/$defs/moduleRegistry" },
        "service": { "$ref": "#/$defs/moduleService" },
        "file": { "$ref": "#/$defs/moduleFile" },
        "directory": { "$ref": "#/$defs/moduleDirectory" },
        "package": { "$ref": "#/$defs/modulePackage" },
        "shortcut": { "$ref": "#/$defs/moduleShortcut" },
        "scheduled_task": { "$ref": "#/$defs/moduleScheduledTask" },
        "user": { "$ref": "#/$defs/moduleUser" },
        "winget_package": { "$ref": "#/$defs/moduleWingetPackage" },
        "remove_appx_packages": { "$ref": "#/$defs/moduleRemoveAppxPackages" },
        "power_plan": { "$ref": "#/$defs/modulePowerPlan" },
        "windows_feature": { "$ref": "#/$defs/moduleWindowsFeature" },
        "environment": { "$ref": "#/$defs/moduleEnvironment" },
        "firewall_rule": { "$ref": "#/$defs/moduleFirewallRule" },
        "powershell": { "$ref": "#/$defs/modulePowershell" },
        "shell": { "$ref": "#/$defs/moduleShell" },
        "reboot": { "$ref": "#/$defs/moduleReboot" },
        "wait": { "$ref": "#/$defs/moduleWait" }
      }
    },
    "taskDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "become": {
          "$ref": "#/$defs/becomeConfig"
        }
      }
    },
    "becomeConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "user": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "load_profile": {
          "type": "boolean"
        }
      }
    },
    "moduleRegistry": {
      "type": "object",
      "description": "Manage Windows registry keys and values",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Registry key path, e.g. HKLM:\\SOFTWARE\\MyApp"
        },
        "user": {
          "type": "string",
          "description": "Optional Windows user for HKCU/HKEY_CURRENT_USER paths"
        },
        "values": {
          "description": "Registry values in legacy map or typed spec-list form",
          "oneOf": [
            {
              "type": "object",
              "description": "Legacy map of value name to value data"
            },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/registryValueSpec" }
            }
          ]
        },
        "ensure": {
          "type": "string",
          "enum": ["present", "absent"],
          "default": "present"
        }
      }
    },
    "registryValueSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["string", "expand_string", "dword", "qword", "binary", "multi_string"]
        },
        "data": {},
        "patch": {
          "type": "array",
          "description": "Binary byte patches for an existing value",
          "items": { "$ref": "#/$defs/registryBinaryPatchSpec" }
        },
        "ensure": {
          "type": "string",
          "enum": ["present", "absent"],
          "default": "present"
        }
      }
    },
    "registryBinaryPatchSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["offset", "data"],
      "properties": {
        "offset": {
          "type": "integer",
          "minimum": 0
        },
        "data": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 255
            },
            {
              "type": "string"
            }
          ]
        }
      }
    },
    "moduleService": {
      "type": "object",
      "description": "Manage Windows services",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Service name"
        },
        "state": {
          "type": "string",
          "enum": ["running", "stopped", "disabled"]
        },
        "startup_type": {
          "type": "string",
          "enum": ["automatic", "manual", "disabled"],
          "description": "Service startup type"
        }
      }
    },
    "moduleFile": {
      "type": "object",
      "description": "Manage files",
      "additionalProperties": false,
      "properties": {
        "src": {
          "type": "string",
          "description": "Source path"
        },
        "dest": {
          "type": "string",
          "description": "Destination path"
        },
        "content": {
          "type": "string",
          "description": "Inline file content to write"
        },
        "content_template": {
          "type": "string",
          "description": "Inline file content template to render before writing; supports secret(\"name\") placeholders"
        },
        "ensure": {
          "type": "string",
          "enum": ["present", "absent"],
          "default": "present"
        }
      }
    },
    "moduleDirectory": {
      "type": "object",
      "description": "Manage directories",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Directory path"
        },
        "ensure": {
          "type": "string",
          "enum": ["present", "absent"],
          "default": "present"
        }
      }
    },
    "modulePackage": {
      "type": "object",
      "description": "Manage installed packages (MSI/EXE)",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "description": "List of packages to manage",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["product_id"],
            "properties": {
              "product_id": { "type": "string", "description": "MSI product GUID for idempotency check" },
              "source": { "type": "string", "description": "Path or UNC path to MSI or EXE installer" },
              "args": { "type": "array", "items": { "type": "string" } },
              "ensure": { "type": "string", "enum": ["present", "absent"], "default": "present" }
            }
          }
        }
      }
    },
    "moduleShortcut": {
      "type": "object",
      "description": "Manage Windows shortcuts (.lnk)",
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string",
          "description": "Target executable or file path"
        },
        "destination": {
          "type": "string",
          "description": "Path where the shortcut file will be created"
        },
        "args": {
          "type": "string",
          "description": "Arguments for the shortcut target"
        },
        "icon": {
          "type": "string",
          "description": "Path to icon file"
        }
      }
    },
    "moduleScheduledTask": {
      "type": "object",
      "description": "Manage Windows scheduled tasks",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Task name"
        },
        "path": {
          "type": "string",
          "description": "Task folder path, e.g. \\Preflight\\"
        },
        "execute": {
          "type": "string",
          "description": "Executable path"
        },
        "arguments": {
          "type": "string",
          "description": "Arguments for the task action"
        },
        "working_dir": {
          "type": "string",
          "description": "Working directory for the task action"
        },
        "trigger": {
          "anyOf": [
            { "type": "string", "enum": ["startup", "onlogon", "daily", "once"] },
            { "type": "string" }
          ],
          "description": "Task trigger"
        },
        "start_at": {
          "type": "string",
          "description": "Start time for daily/once triggers"
        },
        "delay": {
          "type": "string",
          "description": "Delay for startup or onlogon triggers"
        },
        "run_as": {
          "type": "string",
          "description": "User account to run the task as"
        },
        "run_level": {
          "anyOf": [
            { "type": "string", "enum": ["least", "highest"] },
            { "type": "string" }
          ],
          "default": "least"
        },
        "enabled": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string" }
          ],
          "default": true
        },
        "ensure": {
          "anyOf": [
            { "type": "string", "enum": ["present", "absent"] },
            { "type": "string" }
          ],
          "default": "present"
        }
      }
    },
    "moduleUser": {
      "type": "object",
      "description": "Manage local Windows user accounts",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Username"
        },
        "password": {
          "type": "string",
          "description": "User password"
        },
        "groups": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Groups to add the user to"
        },
        "ensure": {
          "type": "string",
          "enum": ["present", "absent"],
          "default": "present"
        }
      }
    },
    "moduleWingetPackage": {
      "type": "object",
      "description": "Manage packages through Windows Package Manager",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "description": "List of packages to manage",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "version": { "type": "string" },
              "source": { "type": "string" },
              "args": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Additional winget command arguments"
              },
              "scope": {
                "type": "string",
                "enum": ["machine", "user"],
                "default": "machine"
              },
              "ensure": {
                "type": "string",
                "enum": ["present", "absent"],
                "default": "present"
              }
            }
          }
        }
      }
    },
    "moduleRemoveAppxPackages": {
      "type": "object",
      "description": "Remove built-in Windows Store-style apps",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "description": "List of packages to remove",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "scope": {
                "type": "string",
                "enum": ["current_user", "all_users", "provisioned", "both"],
                "default": "both"
              },
              "ensure": { "type": "string", "enum": ["absent"], "default": "absent" }
            }
          }
        }
      }
    },
    "modulePowerPlan": {
      "type": "object",
      "description": "Manage named Windows power plans",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "base": {
          "type": "string"
        },
        "activate": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string" }
          ],
          "default": true
        },
        "settings": {
          "type": "array",
          "items": { "$ref": "#/$defs/powerPlanSetting" }
        },
        "ensure": {
          "anyOf": [
            { "type": "string", "enum": ["present", "absent"] },
            { "type": "string" }
          ],
          "default": "present"
        }
      }
    },
    "powerPlanSetting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subgroup", "setting"],
      "properties": {
        "subgroup": {
          "type": "string"
        },
        "setting": {
          "type": "string"
        },
        "ac_value": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string" }
          ]
        },
        "dc_value": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string" }
          ]
        }
      }
    },
    "moduleWindowsFeature": {
      "type": "object",
      "description": "Manage Windows features/roles",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Windows feature name"
        },
        "ensure": {
          "type": "string",
          "enum": ["present", "absent"],
          "default": "present"
        }
      }
    },
    "moduleEnvironment": {
      "type": "object",
      "description": "Manage environment variables",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Environment variable name"
        },
        "value": {
          "type": "string",
          "description": "Environment variable value"
        },
        "scope": {
          "type": "string",
          "enum": ["machine", "user"],
          "default": "machine",
          "description": "Scope of the environment variable"
        },
        "ensure": {
          "type": "string",
          "enum": ["present", "absent"],
          "default": "present"
        }
      }
    },
    "moduleFirewallRule": {
      "type": "object",
      "description": "Manage Windows Firewall rules",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Firewall rule name"
        },
        "direction": {
          "type": "string",
          "enum": ["inbound", "outbound"]
        },
        "action": {
          "type": "string",
          "enum": ["allow", "block"]
        },
        "protocol": {
          "type": "string",
          "enum": ["tcp", "udp", "any"],
          "default": "tcp"
        },
        "ports": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string" },
            { "type": "array", "items": { "oneOf": [{ "type": "integer" }, { "type": "string" }] } }
          ],
          "description": "Port number(s) or range(s)"
        },
        "ensure": {
          "type": "string",
          "enum": ["present", "absent"],
          "default": "present"
        }
      }
    },
    "modulePowershell": {
      "type": "object",
      "description": "Run PowerShell scripts",
      "additionalProperties": false,
      "properties": {
        "script": {
          "type": "string",
          "description": "Inline PowerShell script"
        },
        "file": {
          "type": "string",
          "description": "Path to a PowerShell script file"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Arguments to pass to the script"
        },
        "check_script": {
          "type": "string",
          "description": "PowerShell check script that returns whether change is needed"
        },
        "creates": {
          "type": "string",
          "description": "Registry key or file path; skip if it already exists (idempotency hint)"
        },
        "working_dir": {
          "type": "string",
          "description": "Working directory for the script"
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Environment variable map for the command"
        }
      }
    },
    "moduleShell": {
      "type": "object",
      "description": "Run shell commands",
      "additionalProperties": false,
      "properties": {
        "cmd": {
          "type": "string",
          "description": "Command to run"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Arguments to pass to the command"
        },
        "creates": {
          "type": "string",
          "description": "File path; skip if it already exists (idempotency hint)"
        },
        "working_dir": {
          "type": "string",
          "description": "Working directory for the command"
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Environment variable map for the command"
        }
      }
    },
    "moduleReboot": {
      "type": "object",
      "description": "Reboot the target machine",
      "additionalProperties": false,
      "properties": {
        "condition": {
          "type": "string",
          "enum": ["always", "if_needed"],
          "default": "if_needed"
        },
        "timeout": {
          "type": "integer",
          "description": "Timeout in seconds to wait for reboot",
          "default": 300
        }
      }
    },
    "moduleWait": {
      "type": "object",
      "description": "Wait for a condition to be true",
      "additionalProperties": false,
      "required": ["condition", "target"],
      "properties": {
        "condition": {
          "type": "string",
          "enum": ["port_open", "file_exists", "service_running"],
          "description": "Condition type to wait for"
        },
        "target": {
          "type": "string",
          "description": "The address:port, file path, or service name to check depending on condition"
        },
        "timeout": {
          "type": "string",
          "description": "Maximum time to wait, as a duration string (e.g. \"5m\", \"30s\", \"1h\")",
          "default": "5m"
        }
      }
    }
  }
}
