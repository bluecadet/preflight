{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://preflight.dev/schema/config.schema.json",
  "title": "Config",
  "description": "Schema for preflight.yml project configuration files",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "string",
      "description": "Project name identifier"
    },
    "environment": {
      "type": "string",
      "description": "Deployment environment, e.g. production, staging"
    },
    "vars": {
      "type": "object",
      "description": "Project-level variables available to all playbooks"
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "identity": {
          "type": "string",
          "description": "Path to an age identity file used to decrypt repo-backed secrets"
        },
        "recipients": {
          "type": "array",
          "items": { "type": "string" },
          "description": "age recipients used when encrypting repo-backed secrets"
        },
        "entries": {
          "type": "object",
          "description": "Logical secret names mapped to encrypted files",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "file": {
                "type": "string",
                "description": "Path to the .age-encrypted secret file"
              },
              "type": {
                "type": "string",
                "description": "Optional secret kind hint"
              }
            },
            "required": ["file"]
          }
        }
      }
    },
    "inventory": {
      "$ref": "https://preflight.dev/schema/inventory.schema.json#/$defs/inventory",
      "description": "Embedded project inventory"
    }
  }
}
